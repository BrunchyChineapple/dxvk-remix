#pragma once

// Hillaire Physically-Based Atmospheric Scattering — sky-path evaluators.
// View-direction functions composed into evalSkyRadiance: clouds, moons,
// night sky (stars + galactic band + shooting stars + airglow), sun disk.
// Closesthit and integrate paths that don't sample sky radiance keep their
// existing atmosphere_common.slangh include only — the sky-only functions
// here then never end up in their compiled SPIR-V.
//
// Cloud and atmosphere helpers used by both the sky path and the ground
// shadow term (intersectSphere, cloudPlanetRadius, computeCloudHeightFraction,
// sampleCloudDensityTextured, intersectCloudLayer, evalCloudGroundShadow,
// getTransmittanceToSun, evalAtmosphereRadiance, hash31, fbmNoise2D, etc.)
// stay in atmosphere_common.slangh and are pulled in via the include below.

#include "rtx/pass/atmosphere/atmosphere_common.slangh"

// ============================================================================
// Sun disk
// ============================================================================

// Evaluate sun disk contribution (for sky miss shaders)
vec3 evalSunDisk(vec3 viewDir, AtmosphereArgs args, bool isZUp = false) {
  // Transform view direction to Y-up space
  vec3 viewDirYUp = isZUp ? vec3(viewDir.x, viewDir.z, viewDir.y) : viewDir;
  viewDirYUp = normalize(viewDirYUp);

  // Check if sun is above horizon - sun disk should NOT be visible when sun is below horizon
  // The sun direction Y component represents elevation (positive = above horizon)
  float sunElevation = args.sunDirection.y;

  // Sun disk MUST be fully gone by 0° elevation (horizon line)
  // Start fading at +2° so it disappears smoothly, fully invisible at 0° and below
  const float kSunsetStart = 0.035f;   // ~2 degrees above horizon - start fading
  const float kSunsetEnd = 0.0f;       // 0 degrees = horizon - fully invisible
  float sunsetFade = smoothstep(kSunsetEnd, kSunsetStart, sunElevation);

  // Early exit if sun is at/below horizon
  if (sunElevation <= 0.0f || sunsetFade <= 0.001f) {
    return vec3(0.0f);  // Sun has set
  }

  float cosAngle = dot(viewDirYUp, args.sunDirection);
  float sunCosRadius = cos(args.sunAngularRadius);

  if (cosAngle >= sunCosRadius) {
    // Looking at the sun disk - apply limb darkening
    float normalizedAngle = acos(cosAngle) / args.sunAngularRadius;
    float limbDarkening = 1.0f - 0.6f * normalizedAngle * normalizedAngle;
    limbDarkening = max(limbDarkening, 0.0f);

    // Get transmittance from camera to sun through atmosphere
    vec3 transmittance = getTransmittanceToSun(vec3(0.0f), args, false);

    // Sun disk is extremely bright relative to sky
    // Apply sunset fade so sun dims and disappears as it sets
    return args.sunIlluminance * transmittance * limbDarkening * sunsetFade * 100.0f;
  }
  return vec3(0.0f);
}

// ============================================================================
// Night sky — stars, galactic band, shooting stars, airglow
// ============================================================================
// Composited inside the Physical Atmosphere sky path; users on the default
// Skybox Rasterization sky mode see no behavior change.

// 3-component integer-lattice hash (sky-only — the cloud layer doesn't need
// a 3-vector hash, it uses hash31 for sample-seam jitter).
vec3 hash33(vec3 p) {
  // Integer hash — avoids sin() which creates visible patterns on GPU
  uvec3 q = uvec3(int(p.x * 1597.0f), int(p.y * 2549.0f), int(p.z * 3571.0f));
  q = (q.x ^ q.y ^ q.z) * uvec3(2654435761u, 2246822519u, 3266489917u);
  q = (q >> 16u) ^ q;
  return vec3(float(q.x), float(q.y), float(q.z)) / 4294967296.0f;
}

// Generate star brightness for a given sky direction
// Returns star color (white-blue-orange based on temperature) and brightness
vec3 evalStarField(vec3 viewDir, AtmosphereArgs args) {
  vec3 totalStars = vec3(0.0f);
  vec3 dir = normalize(viewDir);

  // Sidereal rotation: rotate the sample direction around the celestial pole
  // by args.starRotation degrees, then continue with the rotated direction
  // for galactic-band placement, cube-face indexing, and twinkle phase. The
  // whole pattern (band, individual stars, color temperatures) rotates as
  // one rigid body, matching real-sky behavior.
  //
  // Default axis (elevation 90, azimuth 0) places the celestial pole at +Y
  // (zenith). Combined with starRotation = 0, the Rodrigues formula below
  // reduces to the identity, so unrotated callers see the original pattern
  // unchanged.
  {
    const float kDegToRad = 3.14159265358979323846f / 180.0f;
    float poleElev = args.starAxisElevation * kDegToRad;
    float poleAzi  = args.starAxisRotation  * kDegToRad;
    vec3 axis = vec3(cos(poleElev) * sin(poleAzi),
                     sin(poleElev),
                     cos(poleElev) * cos(poleAzi));

    float rotRad = args.starRotation * kDegToRad;
    float c = cos(rotRad);
    float s = sin(rotRad);
    // Rodrigues' rotation: v_rot = v*c + (k × v)*s + k*(k·v)*(1 - c)
    dir = dir * c + cross(axis, dir) * s + axis * dot(axis, dir) * (1.0f - c);
  }

  float theta = acos(clamp(dir.y, -1.0f, 1.0f));
  float phi = atan2(dir.z, dir.x);

  // Galactic plane: compute distance from the galactic band
  // Band tilted ~60° from vertical, meandering slightly
  float galacticLat = dir.x * 0.866f + dir.y * 0.5f;
  float meander = smoothNoise2D(vec2(phi * 2.0f, theta * 0.5f), 200.0f) * 0.08f;
  galacticLat += meander;
  float galacticDist = abs(galacticLat);

  // Galactic density: more stars near the galactic plane
  float galacticCore = exp(-galacticDist * galacticDist * 300.0f);
  float galacticHalo = exp(-galacticDist * galacticDist * 80.0f);
  float galacticDensity = galacticCore * 0.5f + galacticHalo * 0.25f;

  float bandVariation = smoothNoise2D(vec2(phi * 3.0f + 1.5f, galacticLat * 10.0f), 210.0f);
  galacticDensity *= (0.5f + 0.5f * bandVariation);

  // 3D cube-face grid: project direction onto the dominant axis face of a cube,
  // then use the other two axes as a 2D grid. This gives uniform cell sizes
  // across the entire sphere with no pole singularities or view-dependent artifacts.
  vec3 absDir = abs(dir);
  float maxComp = max(absDir.x, max(absDir.y, absDir.z));

  // Determine which cube face we're on and get 2D coordinates
  vec2 faceUV;
  float faceId;
  if (maxComp == absDir.x) {
    faceUV = dir.yz / absDir.x;
    faceId = dir.x > 0.0f ? 0.0f : 1.0f;
  } else if (maxComp == absDir.y) {
    faceUV = dir.xz / absDir.y;
    faceId = dir.y > 0.0f ? 2.0f : 3.0f;
  } else {
    faceUV = dir.xy / absDir.z;
    faceId = dir.z > 0.0f ? 4.0f : 5.0f;
  }

  // Scale to grid resolution (faceUV ranges from -1 to 1, so 400 gives ~800 cells across)
  float gridScale = 400.0f;
  vec2 gridUV = faceUV * gridScale;
  vec2 gridCell = floor(gridUV);
  vec2 gridFrac = fract(gridUV);

  // Check this cell and neighbors for star centers
  for (int dy = -1; dy <= 1; dy++) {
    for (int dx = -1; dx <= 1; dx++) {
      vec2 neighbor = vec2(float(dx), float(dy));
      vec2 cell = gridCell + neighbor;

      // Include faceId in hash to avoid star patterns repeating across cube faces
      vec3 cellHash = hash33(vec3(cell, faceId));
      vec2 starPos = neighbor + cellHash.xy - gridFrac;

      // Distance to star center
      float dist = length(starPos);

      // Star brightness from hash (most cells have no visible star)
      float starMag = cellHash.z;

      // Density threshold: lower in the galactic band = more stars visible
      float localThreshold = args.starDensity - galacticDensity * 0.15f;
      if (starMag < localThreshold) continue;

      // Remap magnitude above threshold to brightness
      float brightness = (starMag - args.starDensity) / (1.0f - args.starDensity);
      brightness = brightness * brightness;  // Quadratic falloff for natural magnitude distribution

      // Star point spread function (small Gaussian)
      float psf = exp(-dist * dist * 800.0f);

      // Star color based on temperature (hash-derived)
      // In the galactic band, shift colors toward warm amber/gold core
      // with cooler purple/blue at the edges — matching real Galactic Center
      float temp = hash31(vec3(cell, 1.0f));
      vec3 starColor;

      // Galactic band color gradient: warm core → cool edges
      // galacticDist is 0 at center, increases outward
      float bandInfluence = exp(-galacticDist * galacticDist * 120.0f);  // How deep in the band

      if (bandInfluence > 0.05f) {
        // Inside the galactic band: warm amber/gold/pink gradient
        // Core (bandInfluence ~1.0): warm gold/amber
        // Mid-band: dusty rose/pink
        // Edge (bandInfluence ~0.05): cool blue-purple
        float coreToEdge = 1.0f - bandInfluence;  // 0 = core, 1 = edge

        if (temp > 0.6f) {
          // Warm gold/amber stars (dominant in core)
          vec3 coreColor = vec3(1.0f, 0.82f, 0.45f);    // Warm amber-gold
          vec3 edgeColor = vec3(0.55f, 0.45f, 0.85f);    // Cool blue-purple
          starColor = mix(coreColor, edgeColor, coreToEdge * coreToEdge);
        } else if (temp > 0.25f) {
          // Dusty rose/pink stars (mid-band)
          vec3 coreColor = vec3(0.95f, 0.60f, 0.55f);    // Dusty rose-pink
          vec3 edgeColor = vec3(0.50f, 0.40f, 0.75f);    // Muted purple
          starColor = mix(coreColor, edgeColor, coreToEdge);
        } else {
          // Reddish-orange stars (scattered throughout)
          vec3 coreColor = vec3(1.0f, 0.55f, 0.30f);     // Deep orange-red
          vec3 edgeColor = vec3(0.60f, 0.50f, 0.80f);     // Lavender
          starColor = mix(coreColor, edgeColor, coreToEdge);
        }
      } else {
        // Outside the galactic band: normal star colors
        if (temp > 0.7f) {
          starColor = vec3(0.7f, 0.8f, 1.0f);   // Blue-white (O/B type)
        } else if (temp > 0.3f) {
          starColor = vec3(1.0f, 1.0f, 0.95f);   // White-yellow (F/G type)
        } else {
          starColor = vec3(1.0f, 0.85f, 0.7f);   // Orange (K type)
        }
      }

      // Twinkling: subtle brightness variation over time
      float twinkle = 1.0f;
      if (args.starTwinkleSpeed > 0.0f) {
        float twinklePhase = hash31(vec3(cell, 2.0f)) * 6.283f;
        float twinkleFreq = 0.5f + hash31(vec3(cell, 3.0f)) * 2.0f;
        twinkle = 0.7f + 0.3f * sin(args.timeSeconds * twinkleFreq * args.starTwinkleSpeed + twinklePhase);
      }

      totalStars += starColor * brightness * psf * twinkle;
    }
  }

  return totalStars * args.starBrightness;
}

// Compute night sky contribution (stars + shooting stars + airglow).
// Moons are composited separately by the caller after this.
vec3 evalNightSky(vec3 viewDir, AtmosphereArgs args) {
  float sunElevation = args.sunDirection.y;

  // Night sky visibility: fade in during twilight, full at night
  // Civil twilight ends at -6° (sunDirection.y ≈ -0.105)
  // Stars become visible around nautical twilight
  // sunElevation is sunDirection.y: negative = below horizon
  const float kStarFadeStart = 0.02f;   // Stars start appearing when sun is 1° below horizon
  const float kStarFadeFull = 0.15f;    // Full star brightness when sun is ~8.5° below

  // -sunElevation is positive when sun is below horizon
  float belowHorizon = -sunElevation;
  float nightFactor = smoothstep(kStarFadeStart, kStarFadeFull, belowHorizon);
  if (nightFactor <= 0.0f) return vec3(0.0f);

  // Atmospheric extinction for stars near horizon — gentle fade only
  float viewElevation = viewDir.y;
  float horizonExtinction = smoothstep(-0.02f, 0.1f, viewElevation);

  // Star field (includes galactic density band — no separate nebula overlay needed)
  vec3 stars = evalStarField(viewDir, args) * horizonExtinction;

  // Shooting stars — thin streaks with fading tail
  {
    float slotTime = floor(args.timeSeconds / 4.0f);
    float slotFrac = fract(args.timeSeconds / 4.0f);

    float slotHash = hash31(vec3(slotTime, 0.0f, 42.0f));
    if (slotHash > 0.92f) {
      float startTheta = hash31(vec3(slotTime, 1.0f, 42.0f)) * kPi * 0.5f + 0.3f;
      float startPhi = hash31(vec3(slotTime, 2.0f, 42.0f)) * 2.0f * kPi;

      vec3 streakStart = vec3(
        sin(startTheta) * cos(startPhi),
        cos(startTheta),
        sin(startTheta) * sin(startPhi)
      );

      float streakAng = hash31(vec3(slotTime, 3.0f, 42.0f)) * kPi;
      vec3 streakMoveDir = normalize(vec3(cos(streakAng) * 0.3f, -0.4f, sin(streakAng) * 0.3f));

      float streakLen = 0.05f;  // Longer tail
      vec3 headPos = normalize(streakStart + streakMoveDir * slotFrac * 0.4f);  // Faster travel
      vec3 tailPos = normalize(streakStart + streakMoveDir * (slotFrac * 0.4f - streakLen));

      vec3 v = normalize(viewDir);
      vec3 segVec = headPos - tailPos;
      float segLen = length(segVec);
      if (segLen > 0.001f) {
        vec3 segNorm = segVec / segLen;
        float t = dot(v - tailPos, segNorm);
        t = clamp(t, 0.0f, segLen);
        vec3 closest = tailPos + segNorm * t;
        float dist = length(v - closest);

        // Thinner streak — tighter Gaussian falloff
        float streakBright = exp(-dist * dist * 18000000.0f);

        // Tail gradient: bright head fading to dim tail
        float tailFade = t / max(segLen, 0.001f);
        tailFade = pow(tailFade, 1.5f);

        float timeFade = sin(slotFrac * kPi);

        stars += vec3(1.0f, 0.95f, 0.85f) * streakBright * tailFade * timeFade * 2.0f;
      }
    }
  }

  // Airglow: faint ambient glow of the night sky
  // Slightly brighter near the horizon (van Rhijn effect)
  float airglowHorizonBoost = 1.0f + 0.5f * exp(-viewElevation * 5.0f);
  vec3 airglow = args.nightSkyColor * args.nightSkyBrightness * airglowHorizonBoost;

  return (stars + airglow) * nightFactor;
}

// ============================================================================
// Moon shading
// ============================================================================
// One unified moon disk evaluator that loops over args.moons[MAX_MOONS] in
// the caller. Surface shading is dispatched by MoonParams::surfaceStyle:
//   0 = Rocky    (pale-grey, craters, maria, ray patterns)
//   1 = Volcanic (warm-red, veins, large impact craters, dusty rose terrain)

// 2D disk-space phase illumination — produces a CURVED (elliptical) terminator
// like a real sphere shadow, not a straight line. diskX must be oriented so
// positive X points toward the sun (the caller builds a sun-oriented frame).
//
// phase: 0 = new, 0.25 = first quarter, 0.5 = full, 0.75 = third quarter
// diskX, diskY: position on the disk [-1, 1], X axis toward the sun
// Returns illumination factor [0, 1].
float getPhaseIllumination(float phase, float diskX, float diskY) {
  // The terminator on a sphere projects as an ellipse on the disk.
  //   phase 0.0 (new)  -> terminatorX = +1 (boundary at right edge = all dark)
  //   phase 0.25 (1Q)  -> terminatorX =  0 (boundary at center = right half lit)
  //   phase 0.5 (full) -> terminatorX = -1 (boundary at left edge = all lit)
  //   phase 0.75 (3Q)  -> terminatorX =  0 (boundary at center = right half lit)
  //   phase 1.0 (new)  -> terminatorX = +1 (back to all dark)
  float terminatorX = cos(phase * 2.0f * kPi);

  float diskR = length(vec2(diskX, diskY));
  if (diskR > 1.0f) return 0.0f;

  // Sphere-projected terminator position at this Y coordinate
  float sphereWidth = sqrt(max(0.0f, 1.0f - diskY * diskY));
  float localTerminator = terminatorX * sphereWidth;

  // Lit side is always at diskX > localTerminator.
  return smoothstep(localTerminator - 0.03f, localTerminator + 0.03f, diskX);
}

// Rocky surface shader — pale-grey procedural surface (craters, maria, ray patterns).
// Knob mapping:
//   m.surfaceNoiseScale → multiplies UV scale (feature size)
//   m.surfaceContrast   → multiplies maria-darken weight, ray amplitude
//   m.craterDensity     → multiplies large + small crater contribution
//   m.roughnessAmount   → multiplies micro-roughness amplitude
void computeRockySurfaceDetail(float diskX, float diskY, MoonParams m,
                               out float surfaceDetail, out vec3 surfaceColor) {
  float uvScale = 8.0f * m.surfaceNoiseScale;
  vec2 moonUV = vec2(diskX, diskY) * uvScale;

  // Maria (dark basaltic plains) — smooth multi-octave noise
  float maria = fbmNoise2D(moonUV * 0.4f + vec2(3.7f, 1.2f), 4, 10.0f);
  maria = smoothstep(0.25f, 0.55f, maria);

  // Highland base brightness (maria darken weighted by surfaceContrast)
  float highland = 1.0f - maria * 0.5f * m.surfaceContrast;

  // Large craters — fixed positions with dark interiors and bright rims
  float craters = 0.0f;
  vec2 craterPositions[7];
  craterPositions[0] = vec2(-0.25f, 0.3f);
  craterPositions[1] = vec2(0.35f, -0.15f);
  craterPositions[2] = vec2(-0.1f, -0.35f);
  craterPositions[3] = vec2(0.2f, 0.25f);
  craterPositions[4] = vec2(-0.3f, -0.1f);
  craterPositions[5] = vec2(0.15f, -0.3f);
  craterPositions[6] = vec2(-0.35f, 0.15f);
  float craterSizes[7];
  craterSizes[0] = 0.12f;
  craterSizes[1] = 0.09f;
  craterSizes[2] = 0.15f;
  craterSizes[3] = 0.07f;
  craterSizes[4] = 0.10f;
  craterSizes[5] = 0.06f;
  craterSizes[6] = 0.08f;

  for (int ci = 0; ci < 7; ci++) {
    float crDist = length(vec2(diskX, diskY) - craterPositions[ci]);
    float craterRadius = craterSizes[ci];

    float bowl = 1.0f - smoothstep(craterRadius * 0.3f, craterRadius * 0.9f, crDist);
    float craterShadow = 0.5f;
    float rim = smoothstep(craterRadius * 0.75f, craterRadius * 0.9f, crDist) *
                (1.0f - smoothstep(craterRadius * 0.9f, craterRadius * 1.15f, crDist));

    craters += bowl * 0.3f * craterShadow - rim * 0.1f;
  }
  craters *= m.craterDensity;

  // Small craters — smooth noise threshold
  float smallCraterNoise = fbmNoise2D(moonUV * 2.5f + vec2(7.3f, 2.1f), 3, 20.0f);
  float smallCraters = smoothstep(0.62f, 0.72f, smallCraterNoise) * 0.2f * m.craterDensity;

  // Surface roughness — fine detail
  float roughness = fbmNoise2D(moonUV * 4.0f + vec2(11.1f, 5.5f), 2, 30.0f) * 0.15f * m.roughnessAmount;

  // Streaks/rays from impacts
  float rays = fbmNoise2D(moonUV * 1.5f + vec2(2.3f, 8.7f), 2, 40.0f);
  rays = smoothstep(0.5f, 0.65f, rays) * 0.12f * m.surfaceContrast;

  float detail = highland - craters - smallCraters + roughness + rays;
  surfaceDetail = clamp(detail, 0.3f, 1.15f);

  // Color: maria are warm grey-brown, highlands cool light grey
  surfaceColor = mix(
    vec3(0.78f, 0.76f, 0.72f),  // Maria: warm grey-brown
    vec3(0.95f, 0.94f, 0.92f),  // Highlands: cool light grey
    1.0f - maria
  );
}

// Volcanic surface shader — warm-red procedural surface (veins, large impact
// craters, dusty rose terrain). Same knob mapping rules as the rocky helper.
void computeVolcanicSurfaceDetail(float diskX, float diskY, MoonParams m,
                                  out float surfaceDetail, out vec3 surfaceColor) {
  float uvScale = 6.0f * m.surfaceNoiseScale;
  vec2 surfUV = vec2(diskX, diskY) * uvScale;

  // Large dark volcanic basins
  float volcanic = fbmNoise2D(surfUV * 0.5f + vec2(5.1f, 3.3f), 4, 50.0f);
  volcanic = smoothstep(0.2f, 0.55f, volcanic) * 0.45f * m.surfaceContrast;

  // Surface terrain — medium scale
  float terrain = fbmNoise2D(surfUV * 1.2f + vec2(11.0f, 7.0f), 3, 60.0f) * 0.2f * m.surfaceContrast;

  // Dark veins/canyons
  float veins = fbmNoise2D(surfUV * 2.0f + vec2(7.0f, 3.0f), 3, 70.0f);
  veins = smoothstep(0.55f, 0.68f, veins) * 0.25f * m.surfaceContrast;

  // Fine surface texture (micro-roughness)
  float fineDetail = fbmNoise2D(surfUV * 3.5f + vec2(13.0f, 9.0f), 2, 80.0f) * 0.08f * m.roughnessAmount;

  // Large impact craters — fixed positions
  float craters = 0.0f;
  vec2 craterPos[4];
  craterPos[0] = vec2(-0.2f, -0.25f);
  craterPos[1] = vec2(0.25f, 0.15f);
  craterPos[2] = vec2(-0.15f, 0.3f);
  craterPos[3] = vec2(0.3f, -0.2f);
  float craterSz[4];
  craterSz[0] = 0.15f;
  craterSz[1] = 0.12f;
  craterSz[2] = 0.10f;
  craterSz[3] = 0.08f;

  for (int mci = 0; mci < 4; mci++) {
    float dist = length(vec2(diskX, diskY) - craterPos[mci]);
    float cr = craterSz[mci];
    float interior = 1.0f - smoothstep(cr * 0.5f, cr * 0.85f, dist);
    craters += interior * 0.2f;
  }
  craters *= m.craterDensity;

  float detail = 1.0f - volcanic - veins - craters + terrain + fineDetail;
  surfaceDetail = clamp(detail, 0.35f, 1.1f);

  // Color: dark volcanic basins → deep crimson-purple, lighter terrain → dusty rose
  surfaceColor = mix(
    vec3(0.30f, 0.08f, 0.12f),
    vec3(0.70f, 0.28f, 0.32f),
    clamp(detail, 0.0f, 1.0f)
  );
}

// Render moon disk for moonIdx in args.moons[]. Returns radiance contribution
// for this pixel and writes diskCoverage in [0,1] indicating disk opacity at
// this view direction. Caller composites moons over the night sky using
// `radiance = mix(radiance, moonContrib, coverage)` so opaque parts of the
// disk replace the background (atmosphere + stars) cleanly.
vec3 evalMoonDisk(vec3 viewDir, uint moonIdx, AtmosphereArgs args, out float diskCoverage) {
  diskCoverage = 0.0f;
  if (moonIdx >= MAX_MOONS) return vec3(0.0f);

  MoonParams m = args.moons[moonIdx];
  if (m.enabled < 0.5f) return vec3(0.0f);

  vec3 moonDir = normalize(m.direction);
  if (dot(moonDir, moonDir) < 0.5f) {
    moonDir = normalize(vec3(0.5f, 0.7f, 0.5f));
  }

  float cosAngle = dot(viewDir, moonDir);
  float moonCosRadius = cos(m.angularRadius);
  if (m.angularRadius < 0.001f) {
    moonCosRadius = cos(0.5f * kPi / 180.0f);
  }
  if (cosAngle < moonCosRadius) return vec3(0.0f);

  // Inside the moon disk — fully opaque, blocks stars and atmosphere behind it
  diskCoverage = 1.0f;

  float normalizedAngle = acos(clamp(cosAngle, -1.0f, 1.0f)) / m.angularRadius;

  // Soft edge at disk boundary to avoid hard aliased circle
  float edgeSoftness = smoothstep(1.0f, 0.97f, normalizedAngle);
  diskCoverage *= edgeSoftness;

  float limbDarkening = 1.0f - 0.3f * normalizedAngle * normalizedAngle;
  limbDarkening = max(limbDarkening, 0.0f);

  // Disk-local frame — diskX horizontal, diskY vertical (world-up basis)
  vec3 upVec = abs(moonDir.y) < 0.999f ? vec3(0.0f, 1.0f, 0.0f) : vec3(1.0f, 0.0f, 0.0f);
  vec3 moonRight = normalize(cross(upVec, moonDir));
  vec3 moonUp    = cross(moonDir, moonRight);

  vec3 toView = normalize(viewDir - moonDir * cosAngle);
  float diskX = dot(toView, moonRight) * normalizedAngle;
  float diskY = dot(toView, moonUp)    * normalizedAngle;

  float illumination = getPhaseIllumination(m.phase, diskX, diskY);
  float diffuse = 0.7f + 0.3f * (1.0f - normalizedAngle);

  // Surface shading dispatched by style preset
  float surfaceDetail = 1.0f;
  vec3 surfaceColor = m.color;
  switch (m.surfaceStyle) {
  case 0u:
    computeRockySurfaceDetail(diskX, diskY, m, surfaceDetail, surfaceColor);
    break;
  case 1u:
    computeVolcanicSurfaceDetail(diskX, diskY, m, surfaceDetail, surfaceColor);
    break;
  default:
    surfaceDetail = 1.0f;
    surfaceColor = m.color;
    break;
  }

  // Phase 2 (2026-05-08): unified physical irradiance scaffold.
  // Replaces the prior magic-number scaffolding:
  //   litRadiance = m.color × surfaceColor × m.brightness × limbDark × surfaceDetail × diffuse × moonAirTrans
  // (effectively m.color² × m.brightness × ...) which made disk visibility depend
  // on m.color magnitude squared and the m.brightness=4.0 default. The disk
  // didn't multiply by args.sunIlluminance at all, divorcing disk magnitude from
  // the rest of the lighting pipeline.
  //
  // New: sharedFactor = sunIlluminance × surfaceColor × moonAirTrans × m.brightness / π
  // Albedo (surfaceColor — perturbed by surface noise per pixel) appears
  // exactly once, properly multiplied by sun irradiance. The per-pixel
  // diffuse cosine integrates to phaseGlow × π over the disk, so phase
  // emerges naturally without an explicit phaseGlow multiplier.
  //
  // Magnitude at FNV defaults (m.brightness=1.0, m.color=0.12, central pixel):
  //   sharedFactor ≈ 20 × 0.12 × 0.97 × 1.0 / π ≈ 0.74 per channel
  //   litRadiance  ≈ 0.74 (vs prior ~3.0) -- 4× drop. Recoverable via
  //   m.brightness if user prefers current visual.
  vec3 sharedFactor = computeMoonSharedFactor(m, args, surfaceColor);

  // Lit side: full surface detail × per-pixel diffuse × limb darkening.
  vec3 litRadiance = sharedFactor * surfaceDetail * diffuse * limbDarkening;

  // Dark side: stylistic earthshine-fill, anchored to the same sharedFactor
  // so it tracks sun changes proportionally. m.darkSideBrightness retains
  // its prior semantics (default 0.005 = ~0.5% of fully-lit moon).
  vec3 darkRadiance = sharedFactor * m.darkSideBrightness * limbDarkening;

  // Blend lit and dark by phase illumination
  vec3 moonRadiance = mix(darkRadiance, litRadiance, illumination);
  return max(moonRadiance, vec3(0.0f));
}

// ============================================================================
// Procedural Cloud Rendering (view-direction evaluation)
// ============================================================================
// The cloud density / intersection helpers (sampleCloudDensityTextured,
// intersectCloudLayer, evalCloudGroundShadow, computeCloudHeightFraction,
// cloudPlanetRadius) live in atmosphere_common.slangh so closesthit ground
// shadow paths and getTransmittanceToSun can use them without pulling in the
// view-direction march. evalClouds composes those helpers with
// sampleCloudSunOpticalDepth (defined here, sky-only) and is composited into
// evalSkyRadiance at the bottom of this file.

// Sample raw cloud optical-depth integral along a light direction from a cloud
// sample point. Returns the path integral of density × distance (units: km ×
// dimensionless density), NOT the exponentiated transmittance — callers
// compute exp(-opticalDepth × σ_n) per octave for the Wrenninge multi-scatter
// sum, or `exp(-opticalDepth × 2 × cloudDensity)` for single-octave Beer-Lambert
// (the moon path).
//
// Reuses the main-sample's typeLocal / coverageLocal across all 2 shadow taps
// — spec rationale: noise wavelength (~2km at default scale) is large compared
// to the 1.6km tap span, so the approximation is visually adequate.
float sampleCloudSunOpticalDepth(vec3 cloudHitPos, vec3 sunDir,
                                  float typeLocal, float coverageLocal,
                                  AtmosphereArgs args,
                                  uint2 pixelCoord, uint frameIdx) {
  if (sunDir.y <= 0.01f) return 0.0f;  // Near/below horizon: no meaningful shadow → zero optical depth

  const int kTaps = 2;
  const float kStepKm = 0.8f;
  float opticalDepth = 0.0f;

  // Shadow march intentionally deterministic. Earlier commits jittered the
  // tap positions via fastJitter().y, but with only 2 taps the per-pixel
  // variance in optical depth feeds Beer-Lambert's exp(-x) — a convex
  // function — and Jensen's inequality (E[exp(-X)] > exp(-E[X])) biases the
  // shadow estimate brighter than deterministic by an amount that scales
  // with cloudDensity. At cloudDensity = 1 the bias is small; at the user's
  // preferred cloudDensity = 2 it's large enough to wash out lit cumulus.
  // The view-march jitter (channel x of the same fastJitter call) is fine
  // because it accumulates linearly across many samples; only the shadow
  // estimator's exponential nonlinearity creates this trap. The pixelCoord
  // and frameIdx params are retained on the function signature for callers'
  // convenience even though they go unused here.
  for (int i = 0; i < kTaps; ++i) {
    vec3 p = cloudHitPos + sunDir * (kStepKm * float(i + 1));
    // Project to horizontal plane and compute heightFraction at the tap.
    // Taps that march above the slab top get hf=1 → bell→0 → density=0,
    // which is correct (no clouds outside the slab).
    float d = sampleCloudDensityTextured(p, computeCloudHeightFraction(p, args),
                                          typeLocal, coverageLocal, args,
                                          AtmosphereCloudNoise3D, AtmosphereCloudNoise3DSampler);
    opticalDepth += d;
  }

  // Return path integral (km × density). Direct-extinction sigma = 2 × cloudDensity;
  // higher octaves attenuate it via extinctionScale^n in the multi-scatter sum.
  return opticalDepth * kStepKm;
}

// Evaluate cloud contribution for a view direction via limited ray-march
// through a cloud slab. Returns (rgb = cloud radiance, a = alpha) in Y-up.
//
// Algorithm:
//  1. Intersect base shell (cloudAltitude) and top shell (cloudAltitude +
//     cloudThickness) to get [tEntry, tExit] for the slab.
//  2. Sample low-frequency variance noise once at the entry point and use it
//     to modulate effective coverage (creates non-uniform sky).
//  3. Step through the slab cloudViewSamples times. At each sample:
//       - Sample density (with effective coverage)
//       - Compute sun illumination (2-tap shadow + atmospheric transmittance)
//       - Add ambient + sky-bounce shadow tint + sun-coupled warm tint
//       - Accumulate using analytical Beer-Lambert
//  4. Early-exit when transmittance drops below 0.01.
//  5. Night moonlight contribution is constant per ray (computed outside
//     the sample loop, applied at each step).
vec4 evalClouds(vec3 viewDir, AtmosphereArgs args, uint2 pixelCoord, uint frameIdx) {
  if (args.cloudEnabled < 0.5f || args.cloudCoverageMean < 0.01f || args.cloudViewSamples == 0u) {
    return vec4(0.0f);
  }

  // Looking below the horizon: no cloud layer above us.
  if (viewDir.y <= 0.001f) return vec4(0.0f);

  // Slab geometry — uses the curvature-adjusted cloud planet radius so the
  // dome tightens as cloudCurvature increases. Atmosphere math is unaffected.
  float cloudR = cloudPlanetRadius(args);
  vec3 planetCenter = vec3(0.0f, -cloudR, 0.0f);
  float baseRadius = cloudR + args.cloudAltitude;
  float topRadius  = cloudR + args.cloudAltitude + args.cloudThickness;

  float t0base, t1base, t0top, t1top;
  if (!intersectSphere(vec3(0.0f), viewDir, planetCenter, baseRadius, t0base, t1base)) return vec4(0.0f);
  if (!intersectSphere(vec3(0.0f), viewDir, planetCenter, topRadius,  t0top,  t1top))  return vec4(0.0f);

  // Camera at sea level inside both spheres; we want the "far" hits (positive t).
  float tEntry = t1base;
  float tExit  = t1top;
  if (tEntry >= tExit || tExit <= 0.0f) return vec4(0.0f);
  // tEntry can be negative if camera is already above cloud base; clamp to start march at the camera.
  tEntry = max(tEntry, 0.0f);

  // Spatial variation: type and coverage are independent low-freq noise fields
  // sampled per main march step inside the loop below (Nubis weather-texture
  // style). The crude "variance" mechanism that lived here previously is
  // subsumed by cloudCoverageSpread.

  // Pre-compute lighting terms invariant per sample.
  vec3 sunDir = normalize(args.sunDirection);
  float cosTheta = dot(viewDir, sunDir);

  // Wrenninge multi-scatter coefficients (Hillaire/Frostbite 2016, Schneider/Decima 2015).
  // Each octave represents a higher-order scattering event with reduced energy
  // (a^n), reduced effective extinction (b^n), and reduced phase asymmetry
  // (c^n) so multi-scattered light becomes progressively more isotropic.
  // Replaces the prior `kDiffuseGain × lambert + kPhaseGain × phase` single-
  // scatter approximation that capped lit-side response at ~0.5 × sunIrradiance
  // and produced uniformly muted cumulus regardless of view direction.
  //
  // The isotropic "deep-scatter floor" sits in for the diffusion-limit
  // well-mixed glow inside dense cloud bodies — `kMsIsoStrength ≈ albedo/π`
  // matches the Lambertian peak for a water-droplet cumulus (albedo ≈ 0.9),
  // and shallow `kMsIsoExtinction` lets it penetrate cumulus interiors so
  // bottoms read as bright milky white rather than the flat 4% ambient hack
  // it replaces.
  const float kMsA = 0.5f;                // energy reduction per octave
  const float kMsB = 0.5f;                // extinction reduction per octave
  const float kMsC = 0.5f;                // phase asymmetry reduction per octave
  const float kMsIsoStrength   = 0.286f;  // ≈ albedo/π for water-droplet cumulus
  const float kMsIsoExtinction = 0.25f;   // iso-floor extinction relative to direct sigma
  uint msOctaveCount = clamp(args.cloudMultiScatterOctaves, 1u, 4u);
  float baseSigma = 2.0f * args.cloudDensity;  // direct-extinction coefficient (matches shadow march)

  // Atmospheric transmittance to the sun. Purely a function of sun direction
  // (the simplified ground-level model has no altitude/position dependence),
  // so hoisted out of the march loop. Calling getAtmosphericTransmittanceForDir
  // directly rather than getTransmittanceToSun avoids the cloud-ground-shadow
  // term — clouds shouldn't be self-shadowed by the cloud layer when their
  // own per-sample sun-shadow march already accounts for occlusion.
  vec3 airTrans = getAtmosphericTransmittanceForDir(sunDir, args);

  // Pre-compute warm tint (constant per ray). lowSunFactor peaks near the
  // horizon and fades on both sides — the below-horizon smoothstep gate
  // prevents warmAdd from persisting at night (directLight/ambient already
  // fade via airTrans's twilightFade, but warmAdd has no airTrans gate).
  // Tightened from smoothstep(-0.10, -0.02, ...) so the warm sunset tint
  // is fully gone by ~-3° below horizon instead of lingering to -5.7°.
  float lowSunFactor = saturate(1.0f - sunDir.y * 3.0f)
                     * smoothstep(-0.05f, -0.02f, sunDir.y);
  // pow(0.5 + 0.5*cosTheta, 4): half-Lambert raised to the 4th power. This
  // is the only shape that satisfies all three constraints simultaneously:
  // (1) localized warm peak around the sun direction so the anti-sun sky
  // doesn't read uniformly warm; (2) steep enough falloff that 90° from
  // sun is at 6% intensity, anti-sun side under 1%; (3) strictly positive
  // everywhere except the single anti-pole point — no surface where the
  // function hits zero, so no visible boundary line on the sky sphere.
  // max(cos, 0) had a 90° boundary; plain half-Lambert was too uniform;
  // smoothstep(-0.1, 0.3) had a 96° boundary. The exponent kills both.
  float warmFactor = pow(0.5f + 0.5f * cosTheta, 4.0f);
  vec3 warmAdd = args.sunIlluminance * lowSunFactor * warmFactor * 0.3f * args.cloudSunsetWarmth;

  // Pre-compute night light (constant per ray) + per-moon directional
  // coefficients (consumed per sample). Three contributions to the
  // moonlit-cloud look:
  //   - nightLight (ambient, per-ray): per-moon zenith-cosine fill +
  //     nightSkyColor airglow. Uniform across the cloud volume —
  //     represents moon-bounce and skybounce light from all directions.
  //   - moonDiffuseCoeff[mi] / moonPhaseAmt[mi] (directional, per-ray):
  //     per-moon Lambert and HG-phase-gain response gated by phaseGlow and
  //     cloudMoonBrightness. Split into separate diffuse + phase amounts so
  //     the phase term can be Wrenninge-smoothed across octaves in the
  //     per-sample loop (parallels the sun's msAniso octave sum at line
  //     950 below). Without smoothing, kMoonAnisotropy = 0.85 produces a
  //     visible discrete ring around the moon when the view ray grazes
  //     thin uniform cloud cover.
  //   - moonShadow (per-sample, computed in the march loop below):
  //     ONE 2-tap density march along the brightness-weighted combined
  //     moon direction (combinedMoonDir, computed below) via the same
  //     sampleCloudSunOpticalDepth helper the sun uses. Multiplies the
  //     combined moon coefficients per sample so the cumulus moon-facing
  //     side reads bright while the far side darkens — mirrors sun
  //     behavior. The combined-direction approximation replaces N
  //     independent per-moon shadow marches; see Lever 4 rationale near
  //     the precompute below.
  vec3 nightLight = vec3(0.0f);
  vec3 moonDiffuseCoeff[MAX_MOONS];
  vec3 moonPhaseAmt[MAX_MOONS];
  vec3 moonDirNorm[MAX_MOONS];
  [unroll] for (uint mInit = 0u; mInit < MAX_MOONS; ++mInit) {
    moonDiffuseCoeff[mInit] = vec3(0.0f);
    moonPhaseAmt[mInit]     = vec3(0.0f);
    moonDirNorm[mInit]      = vec3(0.0f, 1.0f, 0.0f);
  }
  {
    float sunElev = sunDir.y;
    float nightFactor = smoothstep(0.02f, -0.05f, sunElev);
    if (nightFactor > 0.001f) {
      for (uint mi = 0u; mi < MAX_MOONS; ++mi) {
        MoonParams m = args.moons[mi];
        if (m.enabled < 0.5f) continue;
        vec3 moonDir = normalize(m.direction);
        float moonDot = max(dot(moonDir, vec3(0.0f, 1.0f, 0.0f)), 0.0f);
        // phaseGlow: smooth 0..1 raised-cosine oscillation peaking at full moon
        // (phase=0.5) and falling to zero at new moon (phase=0 / phase=1).
        // Earlier `1 - abs(cos(phase * 2π))` was off by a factor of two on the
        // angular argument, producing the inverted shape (peaked at quarters,
        // zero at full) — defaulting all moonlit-cloud, ambient-airglow, and
        // moon-halo contributions to zero at the default phase=0.5.
        float phaseGlow = 0.5f - 0.5f * cos(m.phase * 2.0f * kPi);
        // Phase 2 (2026-05-08): nightLight ambient airglow uses sharedFactor
        // for sun-following-ness consistency.
        // Phase 3 Task 1 (2026-05-08): args.cloudMoonBrightness applied as per-path
        // stylistic multiplier; ambient airglow shares the cloud knob.
        // Phase 3 Task 2 (2026-05-08): magnitude factor 0.0015 exposed as
        // args.moonAmbientAirglow for in-game tuning.
        vec3 sharedFactorAmbient = computeMoonSharedFactor(m, args, m.color);
        nightLight += sharedFactorAmbient * args.moonAmbientAirglow
                    * moonDot * phaseGlow * args.cloudMoonBrightness * nightFactor;

        // Directional contribution — only moons above horizon matter for
        // direct illumination of the cloud body.
        if (moonDir.y > 0.01f && args.moonNeeStrength > 0.001f) {
          // Moon-specific cloud response shape (silver-lining contrast).
          // These gains shape the spatial RESPONSE of cloud-moon coupling
          // (peak vs off-axis), not its magnitude. The sun's shared
          // kDiffuseGain/kPhaseGain were calibrated for daylight-magnitude
          // illumination and produce an off-axis-biased response with the
          // moon -- diffuse beats phase. Re-balanced here:
          //   kMoonDiffuseGain  0.10 (vs sun's 0.35)  -- crush uniform glow
          //   kMoonPhaseGain    0.30 (vs sun's 0.20)  -- boost forward scatter
          //   kMoonAnisotropy   0.85 (vs sun's 0.60)  -- sharper HG peak
          // Result: peak (cloud in front of moon) responds at ~1.13;
          // off-axis (60deg from moon) at ~0.09 -- a ~13x contrast.
          // Phase 3 Task 2 (2026-05-08): exposed as RTX_OPTIONs for in-game
          // tuning of silver-lining shape. Defaults preserved.
          // Silver-lining response decomposed into diffuse + phase amounts.
          // Diffuse (Lambert) is direction-independent at the cloud volume
          // scale; phase (HG) needs per-sample, per-octave evaluation in the
          // march loop below, so we precompute only the magnitude scaling
          // here and defer hgPhase() to the loop.
          const float kMoonDiffuseGain = args.moonCloudDiffuseGain;
          const float kMoonPhaseGain   = args.moonCloudPhaseGain;
          float moonLambert = saturate(moonDir.y * 0.8f + 0.2f);
          // Phase 2 (2026-05-08): physical irradiance scaffold.
          // Replaces the prior kMoonIllumScale = 0.05 × cloudMoonBrightness magic-
          // number magnitude (which lacked args.sunIlluminance entirely -- cloud
          // moon contribution didn't track sun-intensity changes). Now uses the
          // unified physical scaffold:
          //   moonIrradiance = sharedFactor × phaseGlow × moonSolidAngleSr
          //                  × moonNeeStrength × nightFactor
          // Where sharedFactor = sunIlluminance × m.color × moonAirTrans
          // × m.brightness / π. moonNeeStrength now scales cloud illumination
          // (in addition to surface NEE) since clouds are part of "the world
          // the moon lights." cloudMoonBrightness slider retires in Task 7.
          vec3 sharedFactor = computeMoonSharedFactor(m, args, m.color);
          float moonSolidAngleSr = 2.0f * kPi * (1.0f - cos(m.angularRadius));
          // Phase 3 (2026-05-08): args.cloudMoonBrightness is the per-path stylistic
          // multiplier (default 24.0 = matches pre-Phase-2 silver-lining at
          // m.brightness=1.0 under FNV tonemapper).
          vec3 moonIrradiance = sharedFactor * phaseGlow * moonSolidAngleSr
                              * args.moonNeeStrength * args.cloudMoonBrightness
                              * nightFactor;
          moonDiffuseCoeff[mi] = moonIrradiance * kMoonDiffuseGain * moonLambert;
          moonPhaseAmt[mi]     = moonIrradiance * kMoonPhaseGain;
          moonDirNorm[mi]      = moonDir;
        }
      }
      nightLight += args.nightSkyColor * args.nightSkyBrightness * nightFactor * 0.5f;
    }
  }

  // Combined-moon shadow direction (Lever 4). Brightness-weighted average of
  // all enabled, above-horizon moons' directions. One shadow march at this
  // direction per density-passing sample replaces N independent marches.
  // Visual delta is near-zero -- with multiple moons you cannot resolve
  // independent cast shadows on the same cloud cell; shadow direction is a
  // perceptual cue, not a per-moon feature.
  vec3 combinedMoonDir          = vec3(0.0f, 1.0f, 0.0f);
  vec3 combinedMoonDiffuseCoeff = vec3(0.0f);
  vec3 combinedMoonPhaseAmt     = vec3(0.0f);
  {
    vec3 sumWeightedDir = vec3(0.0f);
    float sumWeight = 0.0f;
    [unroll] for (uint mi = 0u; mi < MAX_MOONS; ++mi) {
      // Weight by max-channel of total (diffuse + phase amplitude) — both
      // share moonIrradiance so this stays proportional to per-moon
      // brightness, independent of view direction.
      vec3 moonTotal = moonDiffuseCoeff[mi] + moonPhaseAmt[mi];
      float w = max(max(moonTotal.r, moonTotal.g), moonTotal.b);
      if (w > 0.001f) {
        sumWeightedDir           += moonDirNorm[mi] * w;
        sumWeight                += w;
        combinedMoonDiffuseCoeff += moonDiffuseCoeff[mi];
        combinedMoonPhaseAmt     += moonPhaseAmt[mi];
      }
    }
    if (sumWeight > 0.0f && length(sumWeightedDir) > 0.001f) {
      combinedMoonDir = normalize(sumWeightedDir);
    }
  }

  // Ray-march. Per-pixel FAST-noise jitter on the fractional step offset breaks
  // the visible band-rings into a blue-noise pattern that DLSS / temporal
  // averaging converges cleanly. Channel x is the view march; channel y is
  // reserved for sun-shadow tap jitter inside sampleCloudSunOpticalDepth.
  float stepLen = (tExit - tEntry) / float(args.cloudViewSamples);
  float jitter = fastJitter(pixelCoord, frameIdx).x;  // [0, 1) per pixel, FAST-noise stratified
  vec3 accumRadiance = vec3(0.0f);
  float transmittance = 1.0f;

  // Shadow cadence cache (Lever 3). Sun and combined-moon shadow march only
  // every other density-passing sample; reuse cached value on the alternate.
  // Cache is invalidated whenever the density gate fires so we never reuse
  // a stale shadow across an empty interval. Caches the raw optical-depth
  // integral (km × density) — the sun side feeds it into the Wrenninge sum
  // per octave, the moon side exponentiates once for single-octave Beer-Lambert.
  float cachedSunOpticalDepth  = 0.0f;
  float cachedMoonOpticalDepth = 0.0f;
  bool  cacheValid             = false;

  for (uint i = 0u; i < args.cloudViewSamples; ++i) {
    if (transmittance < 0.01f) break;  // early-exit (free perf win)

    float t = tEntry + stepLen * (float(i) + jitter);
    vec3 samplePos = viewDir * t;

    // Sample local type and coverage from the two independent low-freq
    // control noises (separate seeds so type and coverage are decorrelated).
    vec2 sampleXZ = vec2(samplePos.x, samplePos.z);
    float typeNoise     = smoothNoise2D(sampleXZ * args.cloudTypeNoiseScale,     200.0f);
    float coverageNoise = smoothNoise2D(sampleXZ * args.cloudCoverageNoiseScale, 250.0f);
    float typeLocal     = saturate(args.cloudTypeMean     + (typeNoise     - 0.5f) * args.cloudTypeSpread);
    float coverageLocal = saturate(args.cloudCoverageMean + (coverageNoise - 0.5f) * args.cloudCoverageSpread);

    float hf = computeCloudHeightFraction(samplePos, args);
    float density = sampleCloudDensityTextured(samplePos, hf, typeLocal, coverageLocal, args,
                                                AtmosphereCloudNoise3D, AtmosphereCloudNoise3DSampler);
    if (density < 0.001f) {
      cacheValid = false;
      continue;
    }

    // Per-sample lighting (airTrans hoisted above the loop). Sun and combined-
    // moon shadow share a single parity decision so they march together.
    bool reuse = cacheValid && ((i & 1u) == 1u);

    float sunOpticalDepth;
    if (reuse) {
      sunOpticalDepth = cachedSunOpticalDepth;
    } else {
      sunOpticalDepth = sampleCloudSunOpticalDepth(samplePos, sunDir, typeLocal, coverageLocal, args, pixelCoord, frameIdx);
      cachedSunOpticalDepth = sunOpticalDepth;
    }

    // Wrenninge multi-scatter sum: N octaves of phase × Beer-Lambert with
    // attenuating energy, extinction, and HG anisotropy. The first octave
    // (n=0) is the direct single-scatter; subsequent octaves approximate
    // higher-order in-scattering that fills the cloud volume more uniformly
    // and lifts the deep-interior radiance the prior single-scatter model
    // crushed to ~zero. Range at default coefficients: ~0.05 (back-side, lit)
    // to ~0.9 (silver-lining, lit).
    float msAniso   = 0.0f;
    float octEnergy = 1.0f;
    float octSigma  = baseSigma;
    float octPhaseG = args.cloudAnisotropy;
    for (uint oct = 0u; oct < msOctaveCount; ++oct) {
      msAniso += octEnergy * hgPhase(cosTheta, octPhaseG) * exp(-sunOpticalDepth * octSigma);
      octEnergy *= kMsA;
      octSigma  *= kMsB;
      octPhaseG *= kMsC;
    }

    // Isotropic deep-scatter floor (diffusion-limit approximation). Penetrates
    // cumulus interiors via the shallow `kMsIsoExtinction` so dense bodies
    // stay lit — this term IS the bright milky-white cumulus bottom. Replaces
    // the previous flat 0.04 × sunIlluminance ambient hack with a quantity
    // that attenuates correctly inside the cloud and inherits airTrans's
    // sunset color shift.
    float msIso = kMsIsoStrength * exp(-sunOpticalDepth * baseSigma * kMsIsoExtinction);

    vec3 directLight = args.sunIlluminance * airTrans
                     * args.cloudMultiScatterStrength
                     * (msAniso + msIso);

    // Per-sample moon direct light: ONE shadow march along the brightness-
    // weighted combined moon direction (Lever 4), participating in the same
    // cadence cache as the sun shadow (Lever 3). At low local density the
    // unshadowed moon contribution gets crushed by (1 - stepTransmittance)
    // anyway, so we skip the march entirely below kMoonShadowSkipDensity
    // (Lever 5).
    //
    // Phase-only Wrenninge sum applied to the silver-lining HG response.
    // Without smoothing, kMoonAnisotropy = 0.85 produces a visible discrete
    // bright ring around the moon where the view ray grazes thin uniform
    // cloud cover — the HG peak is too sharp against the dark night-sky
    // background. Mirroring the sun's octave loop (line 950) spreads the
    // phase response across progressively broader g values and the ring
    // becomes a smooth gradient. Unlike the sun loop we deliberately do
    // NOT reduce extinction per octave (no octSigma *= kMsB); the moon
    // keeps single-octave Beer-Lambert via the outer moonShadow factor so
    // cumulus interiors stay dark. Wrenninge's deep-body penetration is
    // the sun-side feature we explicitly do not import.
    const float kMoonShadowSkipDensity = 0.05f;
    vec3 moonDirectLight = vec3(0.0f);
    if (any((combinedMoonDiffuseCoeff + combinedMoonPhaseAmt) > vec3(0.001f))) {
      float moonOpticalDepth;
      if (density < kMoonShadowSkipDensity) {
        moonOpticalDepth = 0.0f;  // unshadowed; visible contribution stays small via (1-T) factor
      } else if (reuse) {
        moonOpticalDepth = cachedMoonOpticalDepth;
      } else {
        moonOpticalDepth = sampleCloudSunOpticalDepth(samplePos, combinedMoonDir,
                                                       typeLocal, coverageLocal, args,
                                                       pixelCoord, frameIdx);
        cachedMoonOpticalDepth = moonOpticalDepth;
      }
      float moonShadow = exp(-moonOpticalDepth * baseSigma);
      // Wrenninge phase sum: each octave attenuates energy (kMsA) and
      // anisotropy (kMsC) but NOT extinction. octave 0 is the original
      // sharp peak; later octaves are broader, dimmer fill that fades the
      // ring boundary without lifting deep-body contribution.
      float moonCosTheta = dot(viewDir, combinedMoonDir);
      float msMoonAniso  = 0.0f;
      float octEnergyM   = 1.0f;
      float octPhaseGM   = args.moonCloudAnisotropy;
      for (uint oct = 0u; oct < msOctaveCount; ++oct) {
        msMoonAniso += octEnergyM * hgPhase(moonCosTheta, octPhaseGM);
        octEnergyM  *= kMsA;
        octPhaseGM  *= kMsC;
      }
      // Approximation: (Σ moonContrib_i) * shadow_combined replaces the
      // original Σ(moonContrib_i * shadow_i). Equal iff per-moon shadow
      // values are uniform, which holds at cloud scale where direction is
      // a perceptual cue only.
      moonDirectLight = (combinedMoonDiffuseCoeff
                       + combinedMoonPhaseAmt * msMoonAniso) * moonShadow;
    }

    // Sky-bounce shadow tint: shadowed parts get faint blue contribution.
    // Multiplied by airTrans because the bounce is ultimately sun light —
    // without this gate the term carried full unattenuated sunIlluminance
    // even when the sun was below the horizon, leaving an unnatural blue
    // glow on every cloud at night. `shadowFraction` derives from the
    // single-octave (n=0) transmittance so the tint shape matches the
    // pre-Wrenninge behavior — only the cloud body lighting changed.
    float sunTransmittance_n0 = exp(-sunOpticalDepth * baseSigma);
    float shadowFraction = 1.0f - sunTransmittance_n0;
    vec3 shadowTintAdd = args.cloudShadowTint * args.cloudShadowTintStrength
                       * shadowFraction * args.sunIlluminance * airTrans * 0.05f;

    vec3 sampleColor = args.cloudColor * (directLight + moonDirectLight)
                     + nightLight + shadowTintAdd + warmAdd;

    // Beer-Lambert step (analytical integration of constant emission)
    float effectiveDensity = density * args.cloudDensity;
    float stepTransmittance = exp(-effectiveDensity * stepLen);
    vec3 stepRadiance = sampleColor * (1.0f - stepTransmittance);
    accumRadiance += stepRadiance * transmittance;
    transmittance *= stepTransmittance;

    cacheValid = true;
  }

  float alpha = 1.0f - transmittance;
  return vec4(accumRadiance, alpha);
}

// ============================================================================
// Sky entry point
// ============================================================================

// Main evaluation function - computes atmosphere directly instead of using sky view LUT.
//
// `enableCloudTemporalSmoothing` (fork) — when true, the cloud layer alpha
// blends against the previous frame's screen-space cloud history at the same
// pixel coordinate before compositing. Kills the DLSS-perceived flatness that
// the per-frame FAST-noise jitter (added in commits 148e3fa5 and d327f3d8)
// otherwise produces. The blend uses a fixed history weight (0.92) which
// matches the volumetric system's age-EMA settled state after ~10 frames.
//
// History rejection: a history sample is discarded — and the raw current
// value used in its place — when ANY of the following hold:
//   1. The reprojected previous coordinate falls off-screen.
//   2. The history slot's frame-id (companion R16_UINT ping-pong) does not
//      equal `(frameIdx - 1) & 0xFFFFu`. This catches stale history at
//      pixels that were foreground-occluded last frame and so were not
//      refreshed by the sky-miss path — the cause of the bright trailing
//      ghosts addressed in the 2026-05-13 follow-up.
//   3. Previous-alpha is near zero (no cloud history at this position).
//
// Pass true ONLY from the primary view ray (geometry_resolver miss path).
// PSR / indirect / NRC paths must pass false — they call evalSkyRadiance with
// non-primary directions, so the screen-space history at their pixelCoord
// would be visually wrong (would smear primary cloud into reflections).
//
// `isPrimaryRay` (fork — 2026-05-12, C5) — when true AND
// args.cloudRenderRTEnable != 0, the cloud layer is read from the prerendered
// AtmosphereCloudRender RT (written each frame by cloud_render.comp.slang
// with Nubis Cubed 2023 lighting) instead of calling analytical evalClouds.
// The RT is at primary-ray pixel coordinates — sampling it from a PSR /
// indirect / reflection ray would return the wrong cloud (different view
// direction at the same pixel), so non-primary call sites pass false and
// fall through to evalClouds. The temporal-smoothing path applies on top of
// either source uniformly because both produce the same (rgb-pre-step,
// opacity) shape; see the alpha-convention note at the branch.
vec3 evalSkyRadiance(
  vec3 viewDir,
  AtmosphereArgs args,
  uint2 pixelCoord,
  uint frameIdx,
  bool isZUp = false,
  bool enableCloudTemporalSmoothing = false,
  vec2 motionVectorPixels = vec2(0.0f, 0.0f),
  uint2 historyResolution = uint2(0u, 0u),
  bool isPrimaryRay = false
) {
  // Transform view direction to Y-up space if needed
  vec3 viewDirYUp = isZUp ? vec3(viewDir.x, viewDir.z, viewDir.y) : viewDir;
  viewDirYUp = normalize(viewDirYUp);
  vec3 sunDir = args.sunDirection;

  // Compute atmosphere directly with fixed step size
  vec3 cameraPos = vec3(0.0f, 0.0f, 0.0f);  // Ground level in Y-up space

  // Compute scattered sky radiance with multiscattering
  vec3 radiance = evalAtmosphereRadiance(
    cameraPos,
    viewDirYUp,
    sunDir,
    args,
    32  // numSamples hint (now using fixed physical step size)
  );

  // Suppress residual atmosphere glow at deep night.
  // The ray marching and multiscattering approximation produce small non-zero
  // values even when the sun is well below the horizon. These wash out dim stars
  // and create view-dependent dark blobs in the star field. Fade the atmosphere
  // contribution to zero once the sun is more than ~5° below the horizon.
  {
    float sunElev = args.sunDirection.y;
    float atmosphereFade = smoothstep(-0.09f, 0.0f, sunElev);
    radiance *= atmosphereFade;
  }

  // Add night-sky contribution (stars + airglow + shooting stars).
  // Additive — daytime nightFactor is 0; during twilight and night, stars/airglow fade in.
  // Note: Sun disk rendering removed - direct lighting handles sun contribution.
  radiance += evalNightSky(viewDirYUp, args);

  // Moons composite over the night sky and atmosphere — only visible at night,
  // fade in during twilight. Each moon disk REPLACES the background where
  // it covers (so dark-side stars don't bleed through). Loop over moons in
  // array order: later array indices render on top of earlier ones.
  float moonFade = smoothstep(0.0f, -0.09f, args.sunDirection.y);
  if (moonFade > 0.001f) {
    // Moon glow/halo: soft radial Gaussian falloff around each enabled moon,
    // additive. Rendered before the opaque disks so each disk cleanly
    // replaces the glow under it.
    for (uint gi = 0u; gi < MAX_MOONS; ++gi) {
      MoonParams m = args.moons[gi];
      if (m.enabled < 0.5f) continue;
      vec3 moonDir = normalize(m.direction);
      float cosAngle = dot(viewDirYUp, moonDir);
      float angularDist = acos(clamp(cosAngle, -1.0f, 1.0f));
      // Glow extends to ~2.5x the moon radius with tight Gaussian falloff
      float glowRadius = m.angularRadius * 2.5f;
      if (angularDist < glowRadius) {
        float glowFalloff = angularDist / glowRadius;
        float glow = exp(-glowFalloff * glowFalloff * 6.0f);  // Tighter Gaussian
        // Scale by brightness and phase (fuller = brighter glow)
        // phaseGlow: full at full moon (0.5), zero at new (0 / 1). See the
        // matching definition in evalClouds; mirrored here for the disk halo.
        float phaseGlow = 0.5f - 0.5f * cos(m.phase * 2.0f * kPi);
        phaseGlow = max(phaseGlow, 0.05f);  // minimal glow at new moon
        // Phase 2 (2026-05-08): halo magnitude scaffold uses sharedFactor
        // for sun-following-ness consistency. kHaloMagnitude (= 0.0015,
        // preserved from 27c69c6d's post-phaseGlow-fix tuning) is the
        // stylistic Gaussian-glow strength -- the halo is a stylized
        // diffraction effect, not a strict physics term, so no
        // moonSolidAngleSr factor.
        //
        // Magnitude at FNV defaults (full moon, zenith, m.brightness=1.0):
        //   sharedFactor × 0.0015 × glow ≈ 0.74 × 0.0015 × glow ≈ 1.1e-3 × glow
        // vs prior:
        //   m.color × m.brightness × 0.0015 ≈ 0.88 × 4.0 × 0.0015 ≈ 5.3e-3 × glow
        // Halo drops ~5× at default m.brightness. Recoverable via
        // m.brightness=4.0 if user prefers current visual.
        // Phase 3 Task 2 (2026-05-08): exposed as args.moonHaloMagnitude.
        const float kHaloMagnitude = args.moonHaloMagnitude;
        // Phase 3 (2026-05-08): args.haloMoonBrightness is the per-path stylistic
        // multiplier on halo glow (default 5.0 = matches pre-Phase-2 halo magnitude
        // at m.brightness=1.0 under FNV tonemapper).
        vec3 sharedFactor = computeMoonSharedFactor(m, args, m.color);
        vec3 glowColor = sharedFactor * phaseGlow * glow * kHaloMagnitude
                       * args.haloMoonBrightness * moonFade;
        radiance += glowColor;
      }
    }

    for (uint i = 0u; i < MAX_MOONS; ++i) {
      float coverage = 0.0f;
      vec3 moonContrib = evalMoonDisk(viewDirYUp, i, args, coverage);
      coverage *= moonFade;
      radiance = mix(radiance, moonContrib, coverage);
    }
  }

  // Clouds render on top of everything (atmosphere + stars + moons). They
  // occlude whatever is behind them based on their alpha.
  //
  // C5 (fork — 2026-05-12): primary-ray-only branch reads the prerendered
  // AtmosphereCloudRender RT instead of calling analytical evalClouds. The RT
  // stores vec4(premultiplied_rgb, view_transmittance) — alpha is
  // TRANSMITTANCE. evalClouds returns vec4(rgb, opacity) — alpha is OPACITY.
  // We invert the RT alpha (opacity = 1 - transmittance) so the downstream
  // temporal-smoothing / mix composite operations apply uniformly to either
  // source: both paths are accumulated as `radiance += stepRadiance * T_so_far`,
  // so the rgb-channel semantics match once the alpha convention is reconciled.
  vec4 cloudLayer;
  if (args.cloudRenderRTEnable != 0u && isPrimaryRay) {
    vec4 cloudRT = AtmosphereCloudRender.Load(int3(pixelCoord, 0));
    cloudLayer = vec4(cloudRT.rgb, 1.0f - cloudRT.a);
  } else {
    cloudLayer = evalClouds(viewDirYUp, args, pixelCoord, frameIdx);
  }

  // Temporal cloud smoothing (fork). Per-frame FAST-noise jitter on the cloud
  // ray-march (commits 148e3fa5 / d327f3d8) creates brightness variance that
  // DLSS sees as noise and averages out, producing visible flatness. We blend
  // the raw current cloud against a screen-space history at the reprojected
  // previous-frame pixel to give DLSS a stable signal while preserving the
  // jitter's anti-banding benefits.
  //
  // Algorithm shape mirrors the volumetric system's age-EMA (see
  // submodules/rtxdi/.../volume_integrator.slangh:125-142). Fixed history
  // weight (0.92) matches the volumetric EMA's settled state after ~10
  // frames.
  //
  // Storage convention: AtmosphereCloudHistory stores
  //   (rgb = cloudLayer.rgb * cloudLayer.a, a = cloudLayer.a)
  // — premultiplied radiance. This means an off-screen / disocclusion fallback
  // (zero history) blends to "no clouds" cleanly, and the final composite is
  // `radiance + smoothed.rgb - radiance * smoothed.a` which equals
  // `mix(radiance, smoothed.rgb / max(smoothed.a, eps), smoothed.a)` for
  // smoothed.a > 0 and `radiance` otherwise. We use the additive form to
  // skip the divide.
  //
  // Age-channel disocclusion (fork — 2026-05-13). The color slot above is
  // ONLY written from the sky-miss branch — when a pixel is occluded by
  // foreground geometry the slot retains pre-occlusion radiance for as long
  // as the occlusion lasts, because nothing else writes there. The legacy
  // alpha-only disocclusion guard could not distinguish "valid sky cloud
  // from last frame" from "stale bright cloud from N frames ago, currently
  // occluded but uncovered this frame" — both have alpha > 0 — and so
  // produced ~30-frame bright ghost trails when foreground moved through
  // bright sky or near emissive surfaces. The companion R16_UINT
  // AtmosphereCloudHistoryFrameId{Prev,Curr} pair carries the frame index
  // at which each slot was last refreshed; the read site below rejects any
  // history whose stored frame-id != `(frameIdx - 1) & 0xFFFFu`. Sentinel
  // 0xFFFF is cleared into the buffer at allocation; the wrap once every
  // 65536 frames and frame-0 startup both collide harmlessly with the
  // sentinel for a single one-frame rejection (~18 min cadence at 60fps).
  vec4 smoothedCloud = cloudLayer;  // default: no smoothing
  if (enableCloudTemporalSmoothing && all(historyResolution > uint2(0u, 0u))) {
    vec4 currentPremul = vec4(cloudLayer.rgb * cloudLayer.a, cloudLayer.a);

    // Reproject: previous-frame pixel = current pixel + motion-vector (in pixels).
    // calcMotionVectorForRayMiss returns NDC-delta * resolution, so adding it
    // to the current pixel yields the previous frame's screen-space pixel.
    vec2 prevPixelF = vec2(pixelCoord) + motionVectorPixels;
    int2 prevPixel = int2(floor(prevPixelF + 0.5f));

    bool reprojValid = all(prevPixel >= int2(0, 0))
                    && all(prevPixel < int2(historyResolution));

    if (reprojValid) {
      vec4 history = AtmosphereCloudHistoryPrev[prevPixel];

      // Age check (fork — 2026-05-13). Reject history whose stored frame-id
      // doesn't match the immediately previous frame. The sentinel 0xFFFF
      // collides with the underflow of `0u - 1u` at startup (correct: no
      // history exists yet) and once per 16-bit wrap (~18 min at 60fps,
      // a single rejected blend on affected pixels — imperceptible).
      uint historyFrameId = AtmosphereCloudHistoryFrameIdPrev[prevPixel];
      uint expectedPrevFrameId = (frameIdx - 1u) & 0xFFFFu;
      bool ageValid = (historyFrameId == expectedPrevFrameId)
                   && (historyFrameId != 0xFFFFu);

      // Disocclusion guard: stale-age short-circuits to "use raw current
      // sample." Past that, the legacy alpha-based gate handles the
      // "no cloud here either way" case (both lerp terms zero, blend is
      // zero — still valid). The 0.001 threshold matches the early-exit
      // gate inside evalClouds itself.
      bool historyValid = ageValid
                       && ((history.a > 0.001f) || (currentPremul.a < 0.001f));
      if (historyValid) {
        // Fixed history weight. Higher = smoother but slower to respond to
        // genuine sky changes (sun motion, weather preset changes); lower =
        // less smoothing benefit. 0.92 was picked to settle to within 1% of
        // a stable signal in ~30 frames at 60Hz (~0.5s) while still strongly
        // suppressing the per-frame jitter variance DLSS sees.
        const float kHistoryWeight = 0.92f;
        vec4 blended = lerp(currentPremul, history, kHistoryWeight);
        smoothedCloud = vec4(blended.rgb, blended.a);
      } else {
        smoothedCloud = currentPremul;
      }
    } else {
      smoothedCloud = currentPremul;
    }

    // Write current frame's premultiplied accumulator + frame-id for next
    // frame to read. The frame-id write is what makes the age check above
    // work: any pixel that does NOT reach this write site this frame keeps
    // its old (or sentinel) frame-id and will fail next-frame's age check.
    AtmosphereCloudHistoryCurr[pixelCoord] = smoothedCloud;
    AtmosphereCloudHistoryFrameIdCurr[pixelCoord] = frameIdx & 0xFFFFu;

    // Composite: smoothedCloud is premultiplied, so the standard "over" op
    // is `radiance * (1 - alpha) + premul.rgb`.
    radiance = radiance * (1.0f - smoothedCloud.a) + smoothedCloud.rgb;
  } else {
    // No temporal smoothing — original composite path.
    radiance = mix(radiance, cloudLayer.rgb, cloudLayer.a);
  }

  return max(radiance, vec3(0.0f));
}
