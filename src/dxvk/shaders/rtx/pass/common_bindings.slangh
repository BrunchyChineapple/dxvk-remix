#pragma once

// Note: These common bindings are to only be included in passes, do not include
// this file in any helpers (glsli files). Additionally only h files for the
// concepts are included to avoid dependencies on bindings within these includes.

#include "rtx/pass/common_binding_indices.h"

#include "rtx/pass/raytrace_args.h"
#include "rtx/concept/surface/surface.h"
#include "rtx/concept/surface_material/surface_material.h"
#include "rtx/concept/volume/volume.h"
#include "rtx/concept/volume_material/volume_material.h"
#include "rtx/concept/light/light.h"
#include "rtx/concept/billboard.h"
#include "rtx/utility/gpu_printing.h"

// Note: Texture array may only be up to a size of 2^16
layout(set = BINDING_SET_BINDLESS_TEXTURE2D, binding = 0)
Texture2D textures[];

[allow("parameterBindingsOverlap")]
layout(set = BINDING_SET_BINDLESS_RAW_BUFFER, binding = 0) 
StructuredBuffer<float> geometries[];

[allow("parameterBindingsOverlap")]
layout(set = BINDING_SET_BINDLESS_RAW_BUFFER, binding = 0)
StructuredBuffer<uint16_t> indices[];

[allow("parameterBindingsOverlap")]
layout(set = BINDING_SET_BINDLESS_RAW_BUFFER, binding = 0)
StructuredBuffer<uint32_t> indices32[];

layout(set = BINDING_SET_BINDLESS_SAMPLER, binding = 0)
SamplerState samplers[];

layout(binding = BINDING_ACCELERATION_STRUCTURE)
RaytracingAccelerationStructure topLevelAS;

layout(binding = BINDING_ACCELERATION_STRUCTURE_PREVIOUS)
RaytracingAccelerationStructure previousTopLevelAS;

layout(binding = BINDING_ACCELERATION_STRUCTURE_UNORDERED)
RaytracingAccelerationStructure unorderedTLAS;

layout(binding = BINDING_ACCELERATION_STRUCTURE_SSS)
RaytracingAccelerationStructure sssTLAS;

layout(binding = BINDING_SURFACE_DATA_BUFFER) 
StructuredBuffer<Surface> surfaces;

layout(binding = BINDING_SURFACE_MAPPING_BUFFER) 
StructuredBuffer<int32_t> surfaceMapping;

// Note: Surface Material array indexed by surface index (max SURFACE_INDEX_MAX_VALUE).
// The SharedSurfaceIndex and SharedMediumMaterialIndex GBuffer textures are R32_UINT.
layout(binding = BINDING_SURFACE_MATERIAL_DATA_BUFFER)
StructuredBuffer<MemoryPolymorphicSurfaceMaterial> surfaceMaterials;

// Note: Surface Material Extension array indexed by surface index (max SURFACE_INDEX_MAX_VALUE).
layout(binding = BINDING_SURFACE_MATERIAL_EXT_DATA_BUFFER)
StructuredBuffer<MemoryPolymorphicSurfaceMaterial> surfaceMaterialExtensions;

// Todo: Volumes for consistency with surfaces and for multi-volume support in the future

// Note: Volume Material array may only be up to a size of 2^16
layout(binding = BINDING_VOLUME_MATERIAL_DATA_BUFFER)
StructuredBuffer<MemoryVolumeMaterial> volumeMaterials;

// Note: Light array may only be up to a size of 2^16
layout(binding = BINDING_LIGHT_DATA_BUFFER) 
StructuredBuffer<MemoryPolymorphicLight> lights;

layout(binding = BINDING_PREVIOUS_LIGHT_DATA_BUFFER) 
StructuredBuffer<MemoryPolymorphicLight> previousLights;

layout(binding = BINDING_LIGHT_MAPPING)
StructuredBuffer<uint16_t> lightMapping;

layout(binding = BINDING_BILLBOARDS_BUFFER) 
StructuredBuffer<MemoryBillboard> billboards;

layout(binding = BINDING_BLUE_NOISE_TEXTURE)
Texture2DArray BlueNoise;

layout(binding = BINDING_CONSTANTS)
ConstantBuffer<RaytraceArgs> cb;

layout(binding = BINDING_DEBUG_VIEW_TEXTURE)
RWTexture2D DebugView;

layout(binding = BINDING_GPU_PRINT_BUFFER) 
RWStructuredBuffer<GpuPrintBufferElement> GpuPrintBuffer;

layout(binding = BINDING_VALUE_NOISE_SAMPLER)
Sampler3D<float4> ValueNoiseSampler;

layout(binding = BINDING_SAMPLER_READBACK_BUFFER) 
RWStructuredBuffer<uint32_t> SamplerFeedbackBuffer;

// Atmosphere LUTs - use high binding slots to avoid conflicts with pass-specific bindings
layout(binding = BINDING_ATMOSPHERE_TRANSMITTANCE_LUT)
Texture2D AtmosphereTransmittanceLut;

layout(binding = BINDING_ATMOSPHERE_MULTISCATTERING_LUT)
Texture2D AtmosphereMultiscatteringLut;

layout(binding = BINDING_ATMOSPHERE_SKY_VIEW_LUT)
Texture2D AtmosphereSkyViewLut;

layout(binding = BINDING_ATMOSPHERE_CLOUD_NOISE_3D)
Texture3D<float> AtmosphereCloudNoise3D;

layout(binding = BINDING_ATMOSPHERE_CLOUD_NOISE_SAMPLER)
SamplerState AtmosphereCloudNoise3DSampler;

layout(binding = BINDING_ATMOSPHERE_FAST_NOISE)
Texture2DArray<float2> AtmosphereFastNoise;

// Cloud history textures (fork). See atmosphere_bindings.slangh for full notes.
layout(rgba16f, binding = BINDING_ATMOSPHERE_CLOUD_HISTORY_PREV)
Texture2D<float4> AtmosphereCloudHistoryPrev;

layout(rgba16f, binding = BINDING_ATMOSPHERE_CLOUD_HISTORY_CURR)
RWTexture2D<float4> AtmosphereCloudHistoryCurr;

// Cloud history frame-id ping-pong (fork). R16_UINT companion to the color
// pair above, carrying the frame index at which each pixel was last written
// by the sky-miss path. Used to reject stale history at pixels that were
// foreground-occluded last frame. See atmosphere_bindings.slangh for the
// full mechanism.
layout(r16ui, binding = BINDING_ATMOSPHERE_CLOUD_HISTORY_FRAME_ID_PREV)
Texture2D<uint> AtmosphereCloudHistoryFrameIdPrev;

layout(r16ui, binding = BINDING_ATMOSPHERE_CLOUD_HISTORY_FRAME_ID_CURR)
RWTexture2D<uint> AtmosphereCloudHistoryFrameIdCurr;

// Cloud-occluded sky-ambient transmittance LUT (fork). 2D (azimuth, elevation),
// R16F single-channel, baked per frame from camera position by
// cloud_sky_transmittance_lut.comp.slang. Sampled via the linear/CLAMP sampler
// produced alongside the bake (bound by fork_hooks::bindAtmosphereLuts).
layout(binding = BINDING_ATMOSPHERE_CLOUD_SKY_TRANSMITTANCE_LUT)
Texture2D<float> AtmosphereCloudSkyTransmittanceLut;

// Cloud render RT (Nubis Cubed 2023, fork — 2026-05-12). Screen-space RGBA16F
// at downscale resolution. rgb = premultiplied cloud radiance; a = view-ray
// cloud transmittance. Produced once per frame by cloud_render.comp.slang via
// RtxAtmosphere::dispatchCloudRender (called from computeLuts). Visualized
// standalone via DEBUG_VIEW_CLOUD_RENDER_RT (876). Will feed the sky-miss
// composite path (C5 of the 2026-05-12 workstream).
layout(binding = BINDING_ATMOSPHERE_CLOUD_RENDER_RT)
Texture2D<float4> AtmosphereCloudRender;

// Cloud voxel grids (Nubis Cubed 2023, fork — 2026-05-12). 256x256x32 R16F
// camera-centered tile-wrapped grids storing summed optical depth along the
// sun direction (D_sun) and zenith (D_ambient). Round-robin baked every
// 8 frames by cloud_sun_density_grid.comp.slang /
// cloud_ambient_density_grid.comp.slang. Sampled via the linear/REPEAT cloud
// noise sampler (BINDING_ATMOSPHERE_CLOUD_NOISE_SAMPLER) — horizontal tile-wrap
// matches the frac()-based UVW computation in cloudVoxelWorldToUVW. No
// consumer in this commit; will feed the Nubis Cubed cloud-lighting rewrite.
layout(binding = BINDING_ATMOSPHERE_CLOUD_D_SUN)
Texture3D<float> AtmosphereCloudDSun;

layout(binding = BINDING_ATMOSPHERE_CLOUD_D_AMBIENT)
Texture3D<float> AtmosphereCloudDAmbient;